# Routes for Core Module (Scala 3 + Play 3)
# API v2 endpoints

# Status endpoints (migrated from legacy)
GET     /api/v2/status                      controllers.core.StatusController.index()
GET     /api/v2/status/detailed             controllers.core.StatusController.detailed()

# Health check (alias)
GET     /health                             controllers.core.StatusController.index()

# MongoDB/FerretDB endpoints
GET     /api/v2/mongo/collections           controllers.core.MongoController.listCollections()
GET     /api/v2/mongo/count/:collection     controllers.core.MongoController.countDocuments(collection: String)
GET     /api/v2/mongo/stats                 controllers.core.MongoController.stats()

# PostgreSQL endpoints
GET     /api/v2/postgres/ping               controllers.core.PostgresController.ping()
GET     /api/v2/postgres/info               controllers.core.PostgresController.info()

# BioMaterialTypes endpoints (migrated from legacy)
GET     /api/v2/bioMaterialTypes                      controllers.BioMaterialTypes.list()
POST    /api/v2/bioMaterialTypes                      controllers.BioMaterialTypes.insert()
PUT     /api/v2/bioMaterialTypes                      controllers.BioMaterialTypes.update()
DELETE  /api/v2/bioMaterialTypes/:bmtId               controllers.BioMaterialTypes.remove(bmtId: String)

# Authentication endpoints
POST    /api/v2/login                       controllers.core.Authentication.login()

# Laboratories
GET     /api/v2/laboratory                      controllers.LaboratoriesController.list()
GET     /api/v2/laboratory/descriptive          controllers.LaboratoriesController.listDescriptive()
GET     /api/v2/country                         controllers.LaboratoriesController.listCountries()
GET     /api/v2/provinces/:country              controllers.LaboratoriesController.listProvinces(country: String)
POST    /api/v2/laboratory                      controllers.LaboratoriesController.addLab()
GET     /api/v2/laboratory/:code                controllers.LaboratoriesController.getLaboratory(code: String)
PUT     /api/v2/laboratory                      controllers.LaboratoriesController.updateLab()

# Geneticist
GET     /api/v2/geneticist/:lab                 controllers.GeneticistsController.allGeneticist(lab: String)
POST    /api/v2/geneticist                      controllers.GeneticistsController.addGeneticist()
GET     /api/v2/geneticist                      controllers.GeneticistsController.getGeneticist(geneticistId: Long)
GET     /api/v2/geneticist-users                controllers.GeneticistsController.getGeneticistUsers()
PUT     /api/v2/geneticist                      controllers.GeneticistsController.updateGeneticist()

# Test

GET     /api/v2/testRoute                       controllers.TestFerController.hardcoded()
GET     /api/v2/echo                            controllers.TestFerController.echo(text: String)
