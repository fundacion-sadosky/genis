Pasos para resolver el problema de notifications.
1) En la instancia superior entrar con psql y
\c genisdb;
COPY "APP"."TRACE" TO '/home/genis-user/trace_data.csv' CSV HEADER;
2) En la base de la instancia inferior entro con sql:
 \c genisdb;
 CREATE TABLE "APP"."TRACE2" (
    "ID" bigint,
    "PROFILE" varchar,
    "USER" varchar,
    "DATE" timestamp,
    "TRACE" varchar,
    "KIND" varchar
);
ALTER TABLE IF EXISTS "APP"."TRACE2"
    OWNER to genissqladmin;
COPY "APP"."TRACE2" FROM '/home/genis-user/trace_data.csv' CSV HEADER;
3) WITH ProcessedNotifications AS (
    SELECT
        n."ID",
        n."KIND" AS notification_kind, -- Added to check for 'rejectedProfile'
        n."USER" AS notification_user, -- Added to use as fallback userName
        n."INFO"::jsonb AS original_info_jsonb,
        (n."INFO"::jsonb ->> 'globalCode') AS extracted_global_code_text,
        -- Calculate the final userName based on combined priority rules
        COALESCE(
            -- Priority 1-3: Attempt to find userName from TRACE2 based on specific KINDS or empty TRACE
            (SELECT
                t."USER"
            FROM "APP"."TRACE2" AS t
            WHERE t."PROFILE" = (n."INFO"::jsonb ->> 'globalCode')
            ORDER BY
                CASE
                    WHEN t."KIND" = 'interconectionAproved' THEN 1 -- Highest priority
                    WHEN t."KIND" = 'aprovedProfile' THEN 2      -- Second priority
                    WHEN t."TRACE"::jsonb = '{}' THEN 3          -- Third priority: TRACE is empty JSON
                    ELSE 999                                   -- Fallback for any other kinds/conditions
                END ASC,
                t."DATE" DESC -- Tie-breaker: if multiple matches with same priority, pick newest
            LIMIT 1
            ),
            -- Priority 4: If TRACE2 lookup yielded NULL, and NOTIFICATION.KIND is 'rejectedProfile', use NOTIFICATION.USER
            CASE
                WHEN n."KIND" = 'rejectedProfile' THEN n."USER"
                ELSE NULL -- If not 'rejectedProfile' and TRACE2 lookup is NULL, then final userName is truly NULL
            END
        ) AS final_user_name_text
    FROM "APP"."NOTIFICATION" AS n
    WHERE
        n."KIND" IN ('aprovedProfile', 'rejectedProfile') -- Now include both kinds for processing
        AND (n."INFO"::jsonb ? 'globalCode') -- Ensure 'globalCode' key exists in INFO
        AND NOT (n."INFO"::jsonb ? 'userName') -- Only update if 'userName' is NOT already present
)
UPDATE "APP"."NOTIFICATION" AS n
SET
    "INFO" = (
        SELECT
            '{' ||
            -- 1. Explicitly add 'globalCode' as the first key
            '"globalCode":' || to_json(pn.extracted_global_code_text)::text || ',' ||
            -- 2. Explicitly add 'userName' as the second key
            '"userName":' || COALESCE(to_json(pn.final_user_name_text)::text, 'null') ||
            -- 3. Append the rest of the original keys, if any
            CASE
                -- If, after removing 'globalCode' and 'userName', the remaining object is empty, don't add a comma
                WHEN (pn.original_info_jsonb - 'globalCode' - 'userName')::text = '{}'
                THEN ''
                ELSE
                    -- Otherwise, add a comma and the string representation of the remaining keys
                    -- We remove the outer braces '{' and '}' from the remaining JSON string
                    ',' || substring((pn.original_info_jsonb - 'globalCode' - 'userName')::text FROM 2 FOR length((pn.original_info_jsonb - 'globalCode' - 'userName')::text) - 2)
            END
            || '}' -- Close the main JSON object
        FROM ProcessedNotifications AS pn_sub
        WHERE pn_sub."ID" = pn."ID"
    )::text
FROM
    ProcessedNotifications AS pn
WHERE
    n."ID" = pn."ID";


--EN TODAS LAS INSTANCIAS: 

--Agrego la key "isDesktop":"false" en la columna INFO de la tabla NOTIFICATION cuando KIND es matching (inbox)
UPDATE "APP"."NOTIFICATION"
SET "INFO" = jsonb_set(
    "INFO"::jsonb,          -- Cast varchar to jsonb
    '{isDesktop}',          -- The key to add
    'false'::jsonb,         -- The value (as jsonb)
    true                    -- 'true' means create the key if it doesn't exist
)::text                     -- Cast back to text/varchar to save
WHERE 
    "KIND" = 'matching'
    AND "INFO"::jsonb ? 'isDesktop' = false;

--Agrego la key userName:USER en la columna "TRACE" cuando el tipo es categoryModification
UPDATE "APP"."TRACE"
SET "TRACE" = jsonb_set(
    "TRACE"::jsonb,           -- Cast the existing TRACE string to a JSONB type
    '{userName}',             -- The path to the key you want to add/update
    to_jsonb("USER"::text),   -- Convert the USER column's value to a JSONB string
    true                      -- 'true' ensures the key is created if it doesn't exist
)::character varying          -- Cast the modified JSONB back to character varying
WHERE "KIND" = 'categoryModification';

--Agrego la key multiallelic en false cuando el trace incluye "categoryConfiguration"
UPDATE "APP"."TRACE" AS t
SET
    "TRACE" = jsonb_set(
        t."TRACE"::jsonb,
        '{categoryConfiguration, multiallelic}',
        to_jsonb(false),
        true -- Create the key if it doesn't exist
    )::character varying
WHERE
    t."TRACE"::jsonb ? 'categoryConfiguration' -- Ensure 'categoryConfiguration' key exists
    AND NOT (t."TRACE"::jsonb -> 'categoryConfiguration' ? 'multiallelic'); -- Ensure 'multiallelic' is NOT already present

Agrego el motivo del rechazo de un perfil en la instancia superior cuando el KIND es interconectionRejected.
UPDATE "APP"."TRACE" t
SET "TRACE" = json_build_object('motive', pu."MOTIVE")::text
FROM "APP"."PROFILE_UPLOADED" pu
WHERE t."PROFILE" = pu."GLOBAL_CODE"
  AND t."KIND" = 'interconectionRejected'
  AND pu."MOTIVE" IS NOT NULL
  AND t."TRACE" IS DISTINCT FROM json_build_object('motive', pu."MOTIVE")::text;

UPDATE "APP"."TRACE"
SET "TRACE" = json_build_object('motive', '')::text
WHERE "KIND" = 'interconectionRejected'
  AND ( "TRACE" IS NULL OR btrim("TRACE") = '{}' );

-- Hago que DATE_UPLOADED sea la fecha en la que se replicó el perfil
UPDATE "APP"."PROFILE_UPLOADED" p
SET "DATE_UPLOADED" = to_char(t."DATE", 'YYYY-MM-DD"T"HH24:MI:SS')
FROM "APP"."TRACE" t
WHERE t."ID" = (
  SELECT MIN(t2."ID")
  FROM "APP"."TRACE" t2
  WHERE t2."PROFILE" = p."GLOBAL_CODE"
    AND t2."KIND" = 'interconectionUpdload'
)
AND t."KIND" = 'interconectionUpdload';

UPDATE "APP"."PROFILE_UPLOADED"
SET "DATE_UPLOADED" = to_char(
    ("DATE_UPLOADED"::timestamp), 
    'YYYY-MM-DD HH24:MI:SS.US'
) || ' -03:00:00'
WHERE "DATE_UPLOADED" LIKE '%T%';

-- Ver si hay TRACE repetidos


-- En la instancia inferior agrego las entradas en TRACE de interconectionAproved cuando el perfil fue aprobado en la instancia superior. 
INSERT INTO "APP"."TRACE" ("PROFILE", "USER", "DATE", "TRACE", "KIND")
SELECT 
    t2."PROFILE", 
    t2."USER", 
    t2."DATE", 
    t2."TRACE", 
    'interconectionAproved'  -- <--- Force the new KIND here
FROM "APP"."TRACE2" t2
WHERE 
    -- 1. We are looking for upload records in TRACE2 to convert into approvals
    t2."KIND" = 'interconectionUpdload'

    -- 2. Logic: The Profile must already exist in TRACE with an 'interconectionUpdload'
    AND EXISTS (
        SELECT 1 
        FROM "APP"."TRACE" t_dest
        WHERE t_dest."PROFILE" = t2."PROFILE" 
        AND t_dest."KIND" = 'interconectionUpdload'
    )

    -- 3. Logic: The Profile must NOT already have an 'interconectionAproved' in TRACE
    AND NOT EXISTS (
        SELECT 1 
        FROM "APP"."TRACE" t_dest
        WHERE t_dest."PROFILE" = t2."PROFILE" 
        AND t_dest."KIND" = 'interconectionAproved'
    )
    
    -- 4. Deduplication: Don't insert if we already inserted this specific approval event
    -- (Checks if an approval with the same date/profile/user already exists)
    AND NOT EXISTS (
        SELECT 1
        FROM "APP"."TRACE" t_dup
        WHERE t_dup."PROFILE" = t2."PROFILE"
        AND t_dup."KIND" = 'interconectionAproved'
        AND t_dup."DATE" = t2."DATE"
    );

-- En la instancia provincial - Luego de haber levantado la instancia y corrido los evolutions
UPDATE "APP"."PROFILE_RECEIVED" pr
SET "DATE_RECEIVED" = subquery."determined_date"
FROM (
    SELECT
        t."PROFILE",
        -- Use COALESCE to pick the first non-NULL date:
        -- 1. MIN(DATE) for 'importedFromInferior' KIND
        -- 2. If #1 is NULL (no 'importedFromInferior' found), then MIN(DATE) for any KIND
        COALESCE(
            MIN(CASE WHEN t."KIND" = 'importedFromInferior' THEN t."DATE" END),
            MIN(t."DATE")
        ) AS "determined_date"
    FROM "APP"."TRACE" t
    GROUP BY t."PROFILE"
) AS subquery
WHERE pr."GLOBAL_CODE" = subquery."PROFILE";

UPDATE "APP"."PROFILE_UPLOADED" pu
SET
    "DATE_UPLOADED" = to_char(t_min_date."min_upload_date", 'YYYY-MM-DD HH24:MI:SS')
FROM (
    SELECT
        t."PROFILE",
        MIN(t."DATE") AS min_upload_date -- Get the earliest date for each profile
    FROM
        "APP"."TRACE" t
    WHERE
        t."KIND" = 'interconectionUpdload'
    GROUP BY
        t."PROFILE"
) AS t_min_date
WHERE
    pu."GLOBAL_CODE" = t_min_date."PROFILE";


